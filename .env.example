# Copy to .env.local for local dev, and set the same in Vercel project settings.

# Postgres connection string (Vercel Postgres provides POSTGRES_URL automatically
# when you create the database and link it; locally you can point at any Postgres).
POSTGRES_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Auth.js session secret. Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"
